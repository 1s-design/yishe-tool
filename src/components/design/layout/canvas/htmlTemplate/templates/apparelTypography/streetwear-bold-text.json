{
  "id": "streetwear-bold-text",
  "name": "街头大字",
  "category": "服饰 / 文字排版",
  "description": "粗体无衬线字体，超大字号居中，适合街头风格的态度表达和标语。",
  "tags": ["街头", "大字", "标语", "态度"],
  "difficulty": "simple",
  "printStyle": "cutout",
  "suitableProducts": ["T恤", "卫衣", "帆布包", "帽子"],
  "sceneDescription": "适合年轻人喜欢的街头文化、态度表达，一句话就能成为视觉焦点。短文案效果最佳，建议 2-6 个词。",
  "sortOrder": 200,
  "fields": [
    { "key": "text.main", "label": "主标语", "type": "text", "placeholder": "STAY WILD", "description": "建议 2-6 个词，大写效果更佳" },
    { "key": "text.sub", "label": "副标语", "type": "text", "placeholder": "Est. 2024", "description": "可选：年份、系列名或副标题" },
    { "key": "color.text", "label": "文字颜色", "type": "color" },
    { "key": "color.bg", "label": "背景色", "type": "color" },
    { "key": "style.spacing", "label": "行间距", "type": "number", "min": 0, "max": 100, "step": 5 }
  ],
  "defaults": {
    "text": { "main": "STAY WILD", "sub": "Est. 2024" },
    "color": {
      "text": { "color": "#0f172a", "type": "pure" },
      "bg": { "color": "#ffffff", "type": "pure" }
    },
    "style": { "spacing": 20 }
  },
  "html": "<style>\n  .container{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;background:{{color.bg}};padding:5%;box-sizing:border-box;text-align:center;}\n  .main-text{font-size:clamp(48px, 12vw, 120px);font-weight:900;letter-spacing:-0.02em;line-height:0.85;color:{{color.text}};text-transform:uppercase;margin-bottom:{{style.spacing}}px;font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial,sans-serif;}\n  .sub-text{font-size:clamp(12px, 2vw, 18px);font-weight:600;letter-spacing:0.3em;text-transform:uppercase;color:{{color.text}};opacity:0.6;font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial,sans-serif;}\n</style>\n<div class=\"container\">\n  <div class=\"main-text\">{{text.main}}</div>\n  <div class=\"sub-text\">{{text.sub}}</div>\n</div>"
}
