{
  "id": "japanese-zen-text",
  "name": "日式禅意",
  "category": "服饰 / 文字排版",
  "description": "日式极简美学，留白充足，适合东方哲学风格和文艺青年。",
  "tags": ["日式", "禅意", "留白", "东方美学"],
  "difficulty": "simple",
  "printStyle": "cutout",
  "suitableProducts": ["T恤", "帆布袋", "茶杯", "笔记本"],
  "sceneDescription": "适合喜欢日本文化、禅意生活、极简主义的人群。文字精炼有意境，配合大量留白，营造安静氛围。",
  "sortOrder": 240,
  "fields": [
    { "key": "text.kanji", "label": "汉字/主文字", "type": "text", "placeholder": "侘寂", "description": "1-4 个汉字，有意境的词" },
    { "key": "text.reading", "label": "读音/注释", "type": "text", "placeholder": "WABI-SABI", "description": "可选：读音、英文翻译或注释" },
    { "key": "text.desc", "label": "短描述", "type": "textarea", "placeholder": "Beauty in imperfection", "rows": 2 },
    { "key": "color.ink", "label": "墨色", "type": "color" },
    { "key": "color.paper", "label": "纸色/背景", "type": "color" },
    { "key": "style.size", "label": "汉字大小", "type": "number", "min": 60, "max": 150, "step": 10 }
  ],
  "defaults": {
    "text": { "kanji": "侘寂", "reading": "WABI-SABI", "desc": "Beauty in imperfection" },
    "color": {
      "ink": { "color": "#2c2c2c", "type": "pure" },
      "paper": { "color": "#faf8f5", "type": "pure" }
    },
    "style": { "size": 100 }
  },
  "html": "<style>\n  .container{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8%;box-sizing:border-box;background:{{color.paper}};text-align:center;}\n  .kanji-text{font-size:clamp({{style.size}}px, 15vw, 140px);font-weight:300;color:{{color.ink}};line-height:1.2;font-family:\"Hiragino Sans\",\"Yu Gothic\",\"Meiryo\",sans-serif;letter-spacing:0.1em;}\n  .reading-text{font-size:clamp(10px, 1.8vw, 16px);font-weight:500;color:{{color.ink}};opacity:0.5;letter-spacing:0.4em;margin-top:20px;text-transform:uppercase;font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,sans-serif;}\n  .divider{width:40px;height:1px;background:{{color.ink}};opacity:0.3;margin:25px auto;}\n  .desc-text{font-size:clamp(12px, 2vw, 16px);font-weight:300;color:{{color.ink}};opacity:0.7;font-style:italic;line-height:1.6;font-family:Georgia,\"Times New Roman\",serif;}\n</style>\n<div class=\"container\">\n  <div class=\"kanji-text\">{{text.kanji}}</div>\n  <div class=\"reading-text\">{{text.reading}}</div>\n  <div class=\"divider\"></div>\n  <div class=\"desc-text\">{{text.desc}}</div>\n</div>"
}
