{
  "id": "modern-minimalist-brand",
  "name": "现代极简品牌",
  "category": "服饰 / 文字排版",
  "description": "干净利落的现代设计，适合品牌 LOGO、简约风格的服饰印花。",
  "tags": ["现代", "极简", "品牌", "干净"],
  "difficulty": "simple",
  "printStyle": "cutout",
  "suitableProducts": ["T恤", "卫衣", "托特包", "手机壳"],
  "sceneDescription": "适合新品牌发布、简约系列产品、注重品牌形象的场景。设计干净现代，不会过时，适合各种年龄层。",
  "sortOrder": 230,
  "fields": [
    { "key": "text.brand", "label": "品牌名", "type": "text", "placeholder": "STUDIO.", "description": "品牌或系列名称" },
    { "key": "text.tagline", "label": "标语", "type": "text", "placeholder": "Design & Craft", "description": "可选：品牌标语或副标题" },
    { "key": "color.text", "label": "文字颜色", "type": "color" },
    { "key": "color.dot", "label": "装饰点颜色", "type": "color" },
    { "key": "style.weight", "label": "字重", "type": "number", "min": 100, "max": 900, "step": 100 }
  ],
  "defaults": {
    "text": { "brand": "STUDIO.", "tagline": "Design & Craft" },
    "color": {
      "text": { "color": "#0a0a0a", "type": "pure" },
      "dot": { "color": "#ef4444", "type": "pure" }
    },
    "style": { "weight": 800 }
  },
  "html": "<style>\n  .container{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6%;box-sizing:border-box;background:#ffffff;}\n  .brand-wrapper{display:flex;align-items:center;gap:8px;}\n  .brand-text{font-size:clamp(40px, 9vw, 80px);font-weight:{{style.weight}};color:{{color.text}};letter-spacing:-0.03em;line-height:1;font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial,sans-serif;}\n  .brand-dot{width:clamp(12px, 2vw, 20px);height:clamp(12px, 2vw, 20px);background:{{color.dot}};border-radius:50%;display:inline-block;}\n  .tagline-text{font-size:clamp(12px, 2vw, 18px);font-weight:400;color:{{color.text}};opacity:0.6;letter-spacing:0.15em;text-transform:uppercase;margin-top:15px;font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial,sans-serif;}\n</style>\n<div class=\"container\">\n  <div class=\"brand-wrapper\">\n    <div class=\"brand-text\">{{text.brand}}</div>\n    <div class=\"brand-dot\"></div>\n  </div>\n  <div class=\"tagline-text\">{{text.tagline}}</div>\n</div>"
}
